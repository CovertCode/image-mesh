{
  "server": {
    "port": 3000,
    "host": "0.0.0.0"
  },
  "storage": {
    "base_path": "./uploads",
    "cache_path": "./cache",
    "max_file_size_mb": 10,
    "allowed_mimetypes": ["image/jpeg", "image/png", "image/webp"]
  },
  "image_defaults": {
    "default_format": "webp",
    "default_quality": 75
  },
  "security": {
    "admin_api_key": "admin-super-secret-key"
  }
}