{% extends "layout.njk" %}

{% block content %}
<div class="p-8 max-w-7xl mx-auto fade-in">
    <!-- Gallery Header -->
    <div id="gallery-header" class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl font-bold tracking-tight text-white mb-2">My Gallery</h1>
            <p id="gallery-info" class="text-neutral-400 text-sm">Showing all media assets across your account.</p>
        </div>

        <div class="flex items-center gap-4">
            <!-- Filter Dropdown -->
            <div class="flex items-center gap-2">
                <span class="text-[10px] font-black text-neutral-500 uppercase tracking-widest">Filter:</span>
                <select id="project-filter" onchange="fetchImages(this.value)"
                    class="bg-neutral-900 border border-neutral-800 text-xs font-bold text-blue-500 rounded-lg px-3 py-2 outline-none focus:ring-1 focus:ring-blue-500">
                    <option value="">All Projects</option>
                </select>
            </div>

            <button onclick="fetchImages(document.getElementById('project-filter').value)"
                class="p-2 bg-neutral-900 border border-neutral-800 rounded-lg text-neutral-400 hover:text-white transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                        stroke-width="2" stroke-linecap="round"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden py-20 text-center">
        <div
            class="w-20 h-20 bg-neutral-900 rounded-3xl flex items-center justify-center mx-auto mb-6 text-neutral-700">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 002-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                </path>
            </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">No images found</h3>
        <p class="text-neutral-500 mb-8">This workspace is currently empty.</p>
        <a href="/upload"
            class="inline-block bg-blue-600 text-white font-bold px-8 py-3 rounded-2xl hover:bg-blue-700 transition-all">Start
            Uploading</a>
    </div>

    <!-- Gallery Grid -->
    <div id="image-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <!-- Images injected here -->
    </div>
</div>

<script>
    /**
     * Fetch projects to populate the filter dropdown
     */
    async function loadFilterOptions() {
        if (!window.apikey) return;
        const res = await fetch('/v1/projects', { headers: { 'x-api-key': window.apikey } });
        const data = await res.json();
        const selector = document.getElementById('project-filter');
        if (data.data) {
            data.data.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.slug;
                opt.innerText = p.name;
                selector.appendChild(opt);
            });
        }
    }

    /**
     * Fetch and render images (with optional project filter)
     */
    async function fetchImages(projectSlug = "") {
        const grid = document.getElementById('image-grid');
        const empty = document.getElementById('empty-state');
        const info = document.getElementById('gallery-info');

        if (!window.apikey) return;

        try {
            // Construct URL with optional folder filter
            let url = '/v1/images?limit=100';
            if (projectSlug) url += `&folder=${projectSlug}`;

            const res = await fetch(url, { headers: { 'x-api-key': window.apikey } });
            const data = await res.json();

            if (!data.success) return alert("Failed to load images.");

            if (data.data.length === 0) {
                grid.classList.add('hidden');
                empty.classList.remove('hidden');
                info.innerText = projectSlug ? `No assets found in "${projectSlug}"` : "Your gallery is empty.";
            } else {
                grid.classList.remove('hidden');
                empty.classList.add('hidden');
                info.innerText = projectSlug ? `Viewing assets in "${projectSlug}"` : "Showing all media assets across your account.";

                renderGrid(data.data);
            }
        } catch (err) {
            console.error(err);
            alert("Network error. Could not fetch gallery.");
        }
    }

    /**
     * Build the HTML for the image grid
     */
    function renderGrid(images) {
        const grid = document.getElementById('image-grid');

        // Correcting the malformed viewBox attributes to "0 0 24 24"
        grid.innerHTML = images.map(img => {
            const thumbUrl = `/i/${img.file_path}?w=400&h=400&m=cover`;
            const fullUrl = window.location.origin + `/i/${img.file_path}`;

            return `
            <div class="group relative aspect-square bg-neutral-900 rounded-2xl overflow-hidden border border-neutral-800 hover:border-blue-500/50 transition-all">
                <img src="${thumbUrl}" alt="${img.filename}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 bg-neutral-800">
                
                <!-- Hover Overlay -->
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-between p-4">
                    <div class="flex justify-end gap-2">
                        <!-- Corrected viewBox="0 0 24 24" -->
                        <button onclick="copyToClipboard('${fullUrl}')" title="Copy Link" class="p-2 bg-white/10 hover:bg-white/20 rounded-lg text-white backdrop-blur-md transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                            </svg>
                        </button>
                        
                        <!-- Corrected viewBox="0 0 24 24" -->
                        <button onclick="deleteImage('${img.id}')" title="Delete Asset" class="p-2 bg-red-500/20 hover:bg-red-500/50 rounded-lg text-red-500 backdrop-blur-md transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                        </button>
                    </div>
                    
                    <div>
                        <p class="text-xs font-bold text-white truncate">${img.filename}</p>
                        <p class="text-[9px] font-bold text-neutral-400 uppercase tracking-widest mt-1">${(img.size_bytes / 1024).toFixed(1)} KB</p>
                    </div>
                </div>
            </div>
        `;
        }).join('');
    }
    /**
     * Utility Functions
     */
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text);
        alert("Public URL copied to clipboard!");
    }

    async function deleteImage(id) {
        if (!confirm("Permanently delete this image from the cloud?")) return;

        try {
            const res = await fetch(`/v1/images/${id}`, {
                method: 'DELETE',
                headers: { 'x-api-key': window.apikey }
            });
            if (res.ok) {
                const currentFilter = document.getElementById('project-filter').value;
                fetchImages(currentFilter);
            } else {
                alert("Failed to delete image.");
            }
        } catch (err) {
            alert("Network error during deletion.");
        }
    }

    // Initialize
    window.addEventListener('load', () => {
        loadFilterOptions();
        fetchImages();
    });
</script>
{% endblock %}