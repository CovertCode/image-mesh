<script>
    (function() {
        // Sync User Info from LocalStorage
        const email = localStorage.getItem('userEmail');
        if (email) {
            const username = email.split('@')[0];
            document.getElementById('side-username').innerText = username;
            document.getElementById('side-avatar').innerText = username.substring(0, 2).toUpperCase();
        }

        // Logic to update storage (To be triggered by main page controllers)
        window.updateSidebarStorage = (usedBytes, limitBytes) => {
            const usedMB = (usedBytes / (1024 * 1024)).toFixed(1);
            const limitMB = (limitBytes / (1024 * 1024)).toFixed(0);
            const percent = Math.min((usedBytes / limitBytes) * 100, 100);
            
            document.getElementById('side-storage-bar').style.width = percent + '%';
            document.getElementById('side-storage-text').innerText = `${usedMB} MB of ${limitMB} MB used`;
        };
    })();
</script>