{% extends "layout.njk" %}

{% block content %}
<div class="p-8 max-w-7xl mx-auto fade-in">
    <!-- Page Header -->
    <div class="flex justify-between items-end mb-10">
        <div>
            <h1 class="text-4xl font-bold tracking-tight text-white mb-2">My Projects</h1>
            <p class="text-neutral-400">Organize your assets into dedicated workspaces.</p>
        </div>
        <button onclick="toggleModal(true)"
            class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-6 py-3 rounded-xl transition-all shadow-lg shadow-blue-500/20 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            New Project
        </button>
    </div>

    <!-- Project Table -->
    <div class="bg-neutral-900/40 rounded-3xl border border-neutral-800 overflow-hidden">
        <table class="w-full text-left">
            <thead>
                <tr
                    class="border-b border-neutral-800 text-[10px] font-bold text-neutral-500 uppercase tracking-widest bg-neutral-900/20">
                    <th class="px-8 py-5">Project Name</th>
                    <th class="px-8 py-5">Slug</th>
                    <th class="px-8 py-5">Status</th>
                    <th class="px-8 py-5">Images</th>
                    <th class="px-8 py-5 text-right">Created</th>
                </tr>
            </thead>
            <tbody id="project-list-tbody" class="divide-y divide-neutral-800">
                <!-- Rows injected by JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- Create Project Modal -->
<div id="project-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm hidden">
    <div class="w-full max-w-md glass-panel rounded-3xl p-8 fade-in shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-white">Create New Project</h3>
            <button onclick="toggleModal(false)" class="text-neutral-500 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                    </path>
                </svg>
            </button>
        </div>

        <form id="project-form" onsubmit="handleCreateProject(event)" class="space-y-6">
            <div>
                <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Project
                    Name</label>
                <input type="text" id="p-name" required
                    class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-sm text-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all"
                    placeholder="e.g. Summer Vacation" oninput="autoSlug(this.value)">
            </div>

            <div>
                <label class="block text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Project Slug
                    (Preview)</label>
                <div class="relative">
                    <span class="absolute left-4 top-3.5 text-neutral-500 text-sm">/</span>
                    <input type="text" id="p-slug" readonly
                        class="w-full bg-neutral-900 border border-neutral-700 rounded-xl px-7 py-3 text-sm text-neutral-500 outline-none"
                        placeholder="slug-preview">
                </div>
            </div>

            <div class="flex gap-4 pt-4">
                <button type="button" onclick="toggleModal(false)"
                    class="flex-1 px-4 py-3 rounded-xl border border-neutral-700 text-sm font-semibold text-neutral-300 hover:bg-neutral-800 transition-colors">
                    Cancel
                </button>
                <button type="submit"
                    class="flex-1 px-4 py-3 rounded-xl bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 transition-all shadow-lg shadow-blue-500/20">
                    Create Project
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    /**
     * Fetch and render projects from API.
     */
    async function fetchProjects() {
        if (!window.apikey) return;

        try {
            const res = await fetch('/v1/projects', {
                headers: { 'x-api-key': window.apikey }
            });
            const data = await res.json();

            if (!data.success) return console.error("Project fetch failed");

            const tbody = document.getElementById('project-list-tbody');
            if (data.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="px-8 py-10 text-center text-neutral-500 text-sm italic">No projects found. Create one to get started!</td></tr>';
                return;
            }

            tbody.innerHTML = data.data.map(p => `
                <tr class="hover:bg-white/5 transition-colors group">
                    <td class="px-8 py-5">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-neutral-800 flex items-center justify-center text-neutral-400 group-hover:bg-blue-600/10 group-hover:text-blue-500 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" stroke-width="2"></path></svg>
                            </div>
                            <span class="font-bold text-sm text-white">${p.name}</span>
                        </div>
                    </td>
                    <td class="px-8 py-5">
                        <span class="text-xs font-mono text-neutral-500">/${p.slug}</span>
                    </td>
                    <td class="px-8 py-5">
                        <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-500/10 text-green-500">
                            Active
                        </span>
                    </td>
                    <td class="px-8 py-5 text-sm text-neutral-400">
                        ${p.image_count || 0} items
                    </td>
                    <td class="px-8 py-5 text-right text-xs text-neutral-500 font-medium">
                        ${new Date(p.created_at).toLocaleDateString()}
                    </td>
                </tr>
            `).join('');

        } catch (err) {
            console.error("Fetch Error:", err);
        }
    }

    /**
     * Create a new project via API.
     */
    async function handleCreateProject(e) {
        e.preventDefault();
        const nameInput = document.getElementById('p-name');
        const name = nameInput.value;

        // 1. FRONTEND LOGS
        console.log('[Frontend] Initiating Project Creation');
        console.log('[Frontend] Name:', name);
        console.log('[Frontend] Active API Key (Hashed):', window.apikey ? 'Yes' : 'No');

        if (!window.apikey) return alert("Please select an API Key first.");

        try {
            const res = await fetch('/v1/projects', {
                method: 'POST',
                headers: {
                    'x-api-key': window.apikey,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ name })
            });

            // 2. LOG RESPONSE STATUS
            console.log('[Frontend] Server responded with status:', res.status);

            const data = await res.json();

            // 3. LOG FULL DATA
            console.log('[Frontend] Server response body:', data);

            if (res.ok && data.success) {
                alert("Project created successfully!");
                toggleModal(false);
                fetchProjects();
            } else {
                alert("Error: " + (data.error || 'Unknown server error'));
            }
        } catch (err) {
            console.error('[Frontend] Network Error:', err);
            alert("Network error. Check console for details.");
        }
    }
    
    /**
     * UI Helpers
     */
    function toggleModal(show) {
        document.getElementById('project-modal').classList.toggle('hidden', !show);
        if (!show) document.getElementById('project-form').reset();
    }

    function autoSlug(val) {
        document.getElementById('p-slug').value = val.toLowerCase()
            .replace(/ /g, '-')
            .replace(/[^\w-]+/g, '');
    }

    // Initialize
    window.addEventListener('load', fetchProjects);
</script>
{% endblock %}